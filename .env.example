# Inference Stack Configuration
# Copy this file to .env and fill in your values.

# ── Paths (defaults shown) ──────────────────────────────────────

# Path to turnstone-stack-secrets directory (relative or absolute)
SECRETS_DIR=../turnstone-stack-secrets

# Path to Age private key file for SOPS decryption
AGE_KEYS_FILE=${HOME}/.config/sops/age/keys.txt

# Shared assets directory (for ComfyUI output)
DOCS_ASSETS=${HOME}/docs/assets

# ── Inference Options ───────────────────────────────────────────

# SGLang model path (default: tiny toy model for testing)
SGLANG_MODEL_PATH=facebook/opt-125m

# Tailscale hostname for the inference stack identity
INFERENCE_HOSTNAME=inference-stack
